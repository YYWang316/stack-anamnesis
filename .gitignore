# Private user data — never commit
USER.md
*.private.md

# Local database
db/*.db
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# Run artifacts — local only, never commit
output/

# B.1 fetcher raw outputs (real data, never commit; keep the empty dir)
meta/raw/*
!meta/raw/.gitkeep

# B.2.8 filler produced reports (regenerate on demand; keep the empty dir)
meta/reports/*
!meta/reports/.gitkeep

# Sector reports rebuild on demand
db/sector_reports/*/
!db/sector_reports/.gitkeep

# Secrets directory (API keys, SEC email cache 等)
~/.config/anamnesis/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# Node
node_modules/

# Environment
.env*

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
.claude/settings.local.json
